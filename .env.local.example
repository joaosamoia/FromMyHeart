# ── Firebase (Client SDK) ──
# Cole aqui os valores do firebaseConfig que você copiou do console
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAcHciFyBRP1BfLYRPYYD07DWmJpW3FJBk
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=landing-page-amor.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=landing-page-amor
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=landing-page-amor.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=261861641249
NEXT_PUBLIC_FIREBASE_APP_ID=1:261861641249:web:1e72262864de300e80a760

# ── Firebase Admin (usado só no servidor: webhook, leitura segura) ──
# Gere em: Configurações do Projeto > Contas de serviço > Gerar nova chave privada
# Cole o JSON inteiro em uma linha só (sem quebras)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...", "...": "..."}

# ── Kiwify (webhook de pagamento) ──
KIWIFY_WEBHOOK_SECRET=cole_aqui_o_segredo_do_webhook_kiwify

# Listas (separadas por vírgula) dos IDs de produto na Kiwify que incluem cada
# addon. Um produto "combo" (ex: Eterno + Astral + QR) entra nas DUAS listas.
# Exemplo com os 8 produtos possíveis (2 planos × astral × qr):
KIWIFY_PRODUCT_IDS_ASTRAL=id_1dia_astral,id_1dia_astral_qr,id_eterno_astral,id_eterno_astral_qr
KIWIFY_PRODUCT_IDS_QR=id_1dia_qr,id_1dia_astral_qr,id_eterno_qr,id_eterno_astral_qr

# ── Resend (e-mail de confirmação pós-pagamento) ──
# Cria conta grátis em resend.com (3.000 e-mails/mês, sem cartão).
# Gera a API key em resend.com/api-keys
RESEND_API_KEY=cole_aqui_sua_api_key_do_resend
# Enquanto seu domínio não estiver verificado no Resend, deixe como está —
# funciona sem configuração nenhuma. Depois de verificar seu domínio, troque
# por algo como contato@seusite.com.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── App ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
